# FBReelz Configuration Example
# Copy this file to .env and customize for your environment

# =====================================================
# Server Configuration
# =====================================================

# Your server's IP address or domain
# Used for generating HTTP playlists that can be accessed remotely
FBREELZ_BASE_URL=http://YOUR_SERVER_IP:8081

# Alternative: Use domain name
# FBREELZ_BASE_URL=https://reelz.yourdomain.com

# =====================================================
# Data Directories
# =====================================================

# Main data directory where videos and playlists are stored
FBREELZ_DATA_DIR=/opt/fbreelz/data

# Directory where cookies are stored
FBREELZ_COOKIES=/opt/fbreelz/secrets/cookies.txt

# =====================================================
# Scraping Configuration
# =====================================================

# Maximum number of items to fetch in Phase 1
MAX_ITEMS=30

# Headless mode (true/false)
HEADLESS=true

# =====================================================
# Optional: Advanced Settings
# =====================================================

# Port for serving content
# SERVER_PORT=8081

# Nginx configuration
# NGINX_CONFIG_PATH=/etc/nginx/sites-available/fbreelz
